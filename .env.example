# Malbeot2 환경변수 — EC2에서 cp .env.example .env 후 사용
APP_ENV=production
SECRET_KEY=malbeot-secret-key-change-this

# DB — portfolio-db 컨테이너 (공용 PostgreSQL)
DATABASE_URL=postgresql+asyncpg://malbeot:1234@portfolio-db:5432/malbeot_db

# Claude API
ANTHROPIC_API_KEY=sk-ant-여기에키입력

ACCESS_TOKEN_EXPIRE_MINUTES=60
