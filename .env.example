# 복사해서 .env 파일로 사용하세요
# cp .env.example .env

APP_ENV=production
SECRET_KEY=여기에-안전한-랜덤-문자열-입력

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://malbeot:비밀번호@db:5432/malbeot_db
POSTGRES_USER=malbeot
POSTGRES_PASSWORD=비밀번호
POSTGRES_DB=malbeot_db

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-여기에-키-입력

ACCESS_TOKEN_EXPIRE_MINUTES=60
